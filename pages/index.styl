@import 'kouto-swiss'
@import '../shared/styles/reset.styl'
@import '../shared/styles/default.styl'

.presentation
  letter-spacing: 0.1rem
  margin-bottom: 50px
  h1
    margin: 0
    font-family: "Share Tech Mono", serif
  code
    color: #017ACC

  .youtubeLink
    color: #FF0000

.subscribe
  display: flex
  align-items: center
  justify-content: center

  .subscribeInput
    width: 100%
    max-width: 600px
    background: $black
    color: $white
    height: 50px
    border-radius: 150px
    display: flex
    justify-content: space-between
    align-items: center

    .cta
      margin-right: 10px
      outline: none

    input
      border: none
      background: transparent
      outline: none
      margin: 0 20px
      color: $white
      width: 100%

      &:disabled
        color: darken(@color, 10%)
      
      +placeholder()
        color: $white
        opacity: 0.3

.cta
  background: $white
  border: none
  border-radius: 100px
  padding: 10px
  color: $black
  cursor: pointer
  transition: all 0.2s ease-in-out

  &:hover
    background: darken($white, 10%)

  &:disabled
    background: darken(@background, 10%)
    cursor: not-allowed