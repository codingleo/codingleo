@import '../shared/styles/default.styl' 

.header
  width: 100%
  display: flex
  align-items: center
  justify-content: center
  height: 60px
  color: #000
  background: #fff

  .container
    display: flex
    flex-direction: row
    align-items: center
    justify-content: space-between

.logo
    font-family: "Share Tech Mono", sans-serif
    color: $white
    background: $black
    padding: 3px 10px

.navigation
  text-align: right
  a
    text-decoration: none
    color: #000
    margin: 0 15px
    font-size: 0.8rem
    position: relative

    &:after
      content: ''
      width: 100%
      height: 1px
      position: absolute
      bottom: -10px
      background: transparent
      left: 0
      transition: all 0.2s ease-in-out

    &:hover
      &:after
        background: #000
        bottom: -2px


    &:first-child
      margin-left: 0
    &:last-child
      margin-right: 0