@import 'kouto-swiss'
@import '../shared/styles/reset.styl'
@import '../shared/styles/default.styl'

.presentation
  letter-spacing: 0.1rem
  
  .youtubeLink
    color: #FF0000

.getInTouch
  width: 100%
  text-align: center
  display: flex
  align-items: center
  justify-content: center
  margin: 40px 0

.subscribe
  display: flex
  align-items: center
  justify-content: center

  .subscribeInput
    width: 100%
    max-width: 600px
    background: $black
    color: $white
    height: 50px
    border-radius: 150px
    display: flex
    justify-content: space-between
    align-items: center

    .cta
      margin-right: 10px
      outline: none

    input
      border: none
      background: transparent
      outline: none
      margin: 0 20px
      color: $white
      width: 100%

      &:disabled
        color: darken(@color, 10%)
      
      +placeholder()
        color: $white
        opacity: 0.3

.cta
  background: $white
  border: none
  border-radius: 100px
  padding: 10px
  color: $black
  cursor: pointer
  transition: all 0.2s ease-in-out

  &:hover
    background: darken($white, 10%)

  &:disabled
    background: darken(@background, 10%)
    cursor: not-allowed

.customers
  margin-top: 100px
  
  h3
    font-size: 0.8em

.customerLogos
  width: 100%
  display: flex
  flex-direction: row
  align-items: center
  justify-content: space-around

  .customerLogo
    max-width: 150px
    max-height: 80px
    margin: 0 20px
    display: block