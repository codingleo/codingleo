@import 'kouto-swiss'
@import 'rupture'
@import '../shared/styles/default.styl'

.jumbotrom
  height: ks-calc("50vh - 60px")
  min-height: ks-calc("50vh - 60px")
  padding: 0 20px

.portfolioContainer
  @extend .jumbotrom
  padding: 0
  min-height: 80vh
  height: auto
  background: $black
  color: $white
  flex-wrap: wrap
  align-items: center
  justify-content: center

  .project
    overflow: hidden
    display: flex
    align-items: center
    justify-content: center
    position: relative
    margin: 0
    background: $black
    cursor: pointer
    border: 2px solid $white
    box-sizing: border-box
    transition: all 0.2s ease-in-out      

    img
      opacity: 1
      transition: all 0.2s ease-in-out

    figcaption
      position: absolute
      top: 50%
      right: 0
      transform: translate(100%, -50%)
      padding: 10px
      background: $black
      color: $white
      transition: all 0.2s ease-in-out
    
    +above(1200px)
      width: 25%
      img
        transform: scale(1.3)
    +to-width(1200px)
      width: 33.3%
    +to-width(900px)
      width: 50%
      img
        transform: scale(1.2)
    +to-width(600px)
      width: 100%
      img
        transform: scale(1.5)
        
    
    &:hover
      img
        opacity: 0.3
        transform: translate(20px, 0)
      figcaption
        transform: translate(0, -50%)

    


